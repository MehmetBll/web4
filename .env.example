# Siteyi calistirmak icin bu dosyayi .env olarak kopyala ve degerleri doldur.

PORT=3000

# FiveM icin tek secenek yeterlidir:
# CFX kodu ornek: cfx.re/join/abc123 adresindeki abc123
FIVEM_CFX_CODE=

# Direkt endpoint kullanacaksan ornek: 127.0.0.1:30120
FIVEM_ENDPOINT=
FIVEM_MAX_PLAYERS=128

# Discord sunucu ID'si. Widget JSON icin Discord sunucu ayarlarindan Widget acik olmali.
DISCORD_GUILD_ID=1439035577109446870

# Aktif yetkili sayimi icin yetkili kullanici ID'lerini virgul ile yaz.
# Ornek: 111111111111111111,222222222222222222
DISCORD_STAFF_USER_IDS=
